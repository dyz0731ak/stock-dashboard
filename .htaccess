RewriteEngine On

# ConoHa WING HTTPS強制リダイレクト
# 方法1: X-Forwarded-Proto
RewriteCond %{HTTP:X-Forwarded-Proto} ^http$ [NC]
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# 方法2: SERVER_PORT が80の場合（方法1が効かない場合のフォールバック）
RewriteCond %{HTTP:X-Forwarded-Proto} ^$
RewriteCond %{SERVER_PORT} ^80$
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# ── キャッシュ制御 ──
# HTML・JS・データJSON は毎回再検証（ETag/Last-Modified で 304）。
# Cache-Control が無いとブラウザがヒューリスティックに旧版を握り続け、
# デプロイ後も古いレイアウト・古いロジック・古いデータが表示されてしまうため。
# （森レイアウトはロジックを app.js に分離したため js も対象に追加）
<IfModule mod_headers.c>
  <FilesMatch "\.(html?|js|json)$">
    Header set Cache-Control "no-cache, must-revalidate"
  </FilesMatch>
</IfModule>
